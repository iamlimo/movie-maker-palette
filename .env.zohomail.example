# Zohomail SMTP Configuration
# Copy this file to .env.local and fill in your actual credentials

# Zohomail SMTP Host (use smtp.zoho.com for US, smtp.zohoeu.com for EU)
ZOHO_SMTP_HOST=smtp.zoho.com

# Zohomail SMTP Port (465 for SSL, 587 for TLS)
ZOHO_SMTP_PORT=465

# Your Zohomail email address (e.g., tech@signaturetv.co)
ZOHO_EMAIL=tech@signaturetv.co

# Your Zohomail password or app-specific password
# IMPORTANT: Use an app-specific password for security!
ZOHO_PASSWORD=your_zohomail_password_here

# Admin email (where new tickets alerts are sent, e.g., ceo@signaturetv.co)
ADMIN_EMAIL=ceo@signaturetv.co

# Reply-To email address (where users can reply, can be any domain, e.g., info@gmail.com)
# If not set, defaults to ADMIN_EMAIL
REPLY_TO_EMAIL=info@gmail.com
